# claude-wa configuration (all optional — CLI flags override these).
# Copy to .env and adjust, or just pass flags. Values also persist to
# ~/.claude-wa/config.json after first run.

# Access PIN that must lead every WhatsApp message. Auto-generated if unset.
CLAUDE_WA_PIN=

# Read-only mode (1 = Claude can read/answer but not edit or run shell).
CLAUDE_WA_READONLY=

# Extra allowed sender numbers (comma-separated, digits only). Your own
# messages are always allowed.
CLAUDE_WA_ALLOW=

# Directory Claude runs in (default: current working directory).
CLAUDE_WA_WORKDIR=

# Path to the claude binary (default: `claude` on PATH).
CLAUDE_WA_CLAUDE_BIN=

# Kill a claude/shell run after this many ms (default: 150000).
CLAUDE_WA_TIMEOUT_MS=

# Where WhatsApp auth + config are stored (default: ~/.claude-wa).
CLAUDE_WA_DIR=
