{
  "name": "claude-wa",
  "version": "0.2.0",
  "description": "Turn a WhatsApp number into Claude: a dev console for your self-chat, or (fan mode) a public AI persona your followers can DM — pin the wa.me link in your bio.",
  "type": "module",
  "bin": {
    "claude-wa": "bin/claude-wa.mjs"
  },
  "exports": {
    ".": "./src/bridge.mjs"
  },
  "files": [
    "bin",
    "src",
    "README.md",
    "LICENSE",
    ".env.example"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "start": "node bin/claude-wa.mjs"
  },
  "keywords": [
    "claude",
    "claude-code",
    "whatsapp",
    "baileys",
    "cli",
    "bot",
    "ai",
    "remote",
    "agent"
  ],
  "author": "Dark Lord",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/MukeshSahni1/claude-wa.git"
  },
  "bugs": {
    "url": "https://github.com/MukeshSahni1/claude-wa/issues"
  },
  "homepage": "https://github.com/MukeshSahni1/claude-wa#readme",
  "dependencies": {
    "@hapi/boom": "^10.0.1",
    "@whiskeysockets/baileys": "^6.7.9",
    "pino": "^9.5.0",
    "qrcode-terminal": "^0.12.0"
  }
}
